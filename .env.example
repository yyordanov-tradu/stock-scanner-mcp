# stock-scanner-mcp — Environment Variables
#
# Copy this file to .env and fill in the keys you have.
# Modules with missing keys are automatically skipped at startup.

# Finnhub — enables news, earnings, analyst ratings, company profiles
# Get a free key at: https://finnhub.io/register
FINNHUB_API_KEY=

# Alpha Vantage — enables stock quotes, daily prices, fundamentals, dividends
# Get a free key at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# FRED (Federal Reserve Economic Data) — enables economic calendar, indicators, interest rates
# Get a free key at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=
