{
  "name": "stock-scanner-mcp",
  "version": "0.1.0",
  "description": "Claude Code Plugin for stock and crypto market data",
  "type": "module",
  "bin": {
    "stock-scanner-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "mcp",
    "stock",
    "crypto",
    "tradingview",
    "claude-code"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
