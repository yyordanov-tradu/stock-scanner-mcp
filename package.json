{
  "name": "stock-scanner-mcp",
  "mcpName": "io.github.yyordanov-tradu/stock-scanner-mcp",
  "version": "1.13.1",
  "description": "MCP server providing Claude Code with real-time stock and crypto market data, SEC filings, insider trades, and technical analysis",
  "type": "module",
  "bin": {
    "stock-scanner-mcp": "./dist/index.js",
    "stock-scanner-install-skills": "./dist/install-skills.js",
    "stock-scanner-sidecar": "./dist/sidecar/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts src/install-skills.ts src/sidecar/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "validate-tools": "tsx src/scripts/validate-tools.ts",
    "validate-structure": "tsx src/scripts/validate-structure.ts",
    "prepublishOnly": "npm run build && npm test"
  },
  "files": [
    "dist",
    "skills"
  ],
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "anthropic",
    "claude",
    "claude-code",
    "ai-agent",
    "ai-tools",
    "llm-tools",
    "stock",
    "stock-market",
    "stock-scanner",
    "stock-screener",
    "stock-analysis",
    "crypto",
    "cryptocurrency",
    "trading",
    "trading-skills",
    "investing",
    "market-data",
    "financial-data",
    "tradingview",
    "technical-analysis",
    "fundamental-analysis",
    "price-action",
    "options",
    "options-chain",
    "earnings",
    "sentiment",
    "fear-greed",
    "sec-edgar",
    "insider-trades",
    "economic-data",
    "fred",
    "finnhub",
    "alpha-vantage",
    "coingecko"
  ],
  "author": "Yordan Yordanov",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yyordanov-tradu/stock-scanner-mcp.git"
  },
  "homepage": "https://github.com/yyordanov-tradu/stock-scanner-mcp#readme",
  "bugs": {
    "url": "https://github.com/yyordanov-tradu/stock-scanner-mcp/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.1"
  }
}
